{
  "name": "ADNQN Outreach Sequence (Email + Manual WA)",
  "nodes": [
    {
      "parameters": {
        "path": "outreach-trigger",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "1",
      "name": "Webhook (Next.js)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "custom-outreach-id"
