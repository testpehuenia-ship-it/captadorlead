      "id": "4",
      "name": "Notify Admin for WhatsApp",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [850, 300],
      "notes": "Cambiar por nodo de Slack/Email interno"
    }
  ],
