generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Módulo 1 + 3: Empresas/Leads
model Company {
  id           String        @id @default(cuid())
  name         String
  rubro        String
  localidad    String
  country      String        @default("AR")
  phone        String?
  email        String?
  website      String?
  address      String?
  googleMapsUrl String?
  googleRating Float?
  googleReviews Int?
  schedule     Json?         // Horarios
  instagram    String?
  facebook     String?
  linkedin     String?
  tiktok       String?
  
  // Módulo 3: Clasificación
  category     LeadCategory  // CON_WEB | SIN_WEB_CON_CONTACTO | SOLO_REDES | INSUFICIENTE
  
  // Módulo 12: IA Comercial
  leadScore    LeadScore     @default(COLD) // COLD | WARM | INTERESTED | HOT | OPPORTUNITY
  aiScore      Float?        // 0-100 score numérico
  
  // Metadata
  source       String?       // "google_places" | "manual" | "csv"
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  // Relaciones
  enrichments  Enrichment[]
  audits       Audit[]
  deals        Deal[]
  activities   Activity[]
  outreach     OutreachLog[]
  proposals    Proposal[]
}

// Módulo 2: Enriquecimiento
model Enrichment {
  id           String   @id @default(cuid())
  company      Company  @relation(fields: [companyId], references: [id])
  companyId    String
  
  emails       String[] // Emails detectados
  forms        Json?    // Formularios encontrados
  techStack    Json?    // { wordpress: true, version: "6.4", plugins: [...] }
  ssl          Boolean?
  cms          String?
  framework    String?
  
  createdAt    DateTime @default(now())
}

// Módulos 4 + 5 + 6: Auditorías
model Audit {
  id           String    @id @default(cuid())
  company      Company   @relation(fields: [companyId], references: [id])
  companyId    String
  type         AuditType // SEO | GEO | TECH | FULL
  
  // SEO (Módulo 4)
  seoScore     Float?
  https        Boolean?
  lcp          Float?
  inp          Float?
  cls          Float?
  hasSitemap   Boolean?
  hasRobots    Boolean?
  metaTitle    String?
  metaDesc     String?
  h1Count      Int?
  
  // GEO (Módulo 5)
  geoScore     Float?
  hasSchema    Boolean?
  schemaTypes  String[]
  eeatScore    Float?
  allowsAiBots Boolean?
  hasFaq       Boolean?
  hasAuthor    Boolean?
  
  // Obsolescencia (Módulo 6)
  wordpressVersion String?
  outdatedPlugins  Int?
  securityIssues   Json?
  
  rawResults   Json?
  createdAt    DateTime @default(now())
}

// Módulo 7 + 8: Propuestas e Informes
model Proposal {
  id           String         @id @default(cuid())
  company      Company        @relation(fields: [companyId], references: [id])
  companyId    String
  
  winThemes    Json?          // 3-5 win themes del skill proposal-strategist
  content      String         // Propuesta completa en markdown
  pdfUrl       String?        // URL al PDF generado en Supabase Storage
  status       ProposalStatus @default(DRAFT)
  
  createdAt    DateTime       @default(now())
  sentAt       DateTime?
}

// Módulo 9 + 10 + 11: Outreach
model OutreachLog {
  id           String        @id @default(cuid())
  company      Company       @relation(fields: [companyId], references: [id])
  companyId    String
  channel      Channel       // EMAIL | WHATSAPP | INSTAGRAM | FACEBOOK | LINKEDIN
  touchNumber  Int           // Touch 1-10 (secuencia del skill outbound-strategist)
  status       OutreachStatus // SENT | DELIVERED | OPENED | REPLIED | BOUNCED
  subject      String?
  content      String
  sentAt       DateTime      @default(now())
}

// Módulo 13: CRM Pipeline
model Deal {
  id           String    @id @default(cuid())
  company      Company   @relation(fields: [companyId], references: [id])
  companyId    String
  
  stage        DealStage // LEAD | CONTACTED | QUALIFIED | PROPOSAL | NEGOTIATION | WON | LOST
  value        Float?
  currency     String    @default("ARS")
  probability  Float?    // % de cierre (pipeline analyst MEDDPICC)
  closeDate    DateTime?
  notes        String?
  
  // MEDDPICC Score (skill agency-pipeline-analyst)
  meddpiccScore Int?     // 0-16
  
  assignedTo   String?   // userId
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Actividad CRM
model Activity {
  id           String       @id @default(cuid())
  company      Company      @relation(fields: [companyId], references: [id])
  companyId    String
  type         ActivityType // CALL | EMAIL | MEETING | NOTE | TASK
  description  String
  scheduledAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
}

// Módulo 14: Agenda / Reuniones
model Meeting {
  id           String      @id @default(cuid())
  companyId    String
  platform     MeetPlatform // MEET | TEAMS | ZOOM | CALENDLY
  title        String
  scheduledAt  DateTime
  duration     Int         // minutos
  meetUrl      String?
  status       MeetStatus  @default(SCHEDULED)
  createdAt    DateTime    @default(now())
}

// ENUMS
enum LeadCategory {
  CON_WEB
  SIN_WEB_CON_CONTACTO
  SOLO_REDES
  INSUFICIENTE
}

enum LeadScore {
  COLD
  WARM
  INTERESTED
  HOT
  OPPORTUNITY
}

enum AuditType {
  SEO
  GEO
  TECH
  FULL
}

enum DealStage {
  LEAD
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum Channel {
  EMAIL
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  TIKTOK
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
}

enum MeetPlatform {
  MEET
  TEAMS
  ZOOM
  CALENDLY
}

enum MeetStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum OutreachStatus {
  SENT
  DELIVERED
  OPENED
  REPLIED
  BOUNCED
}
